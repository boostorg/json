import common ;
import path ;
import property-set ;
import stage ;
import type ;
import virtual-target ;
import "class" : new ;


generate printers
    : boost_json_printers.py
      /boost/json//boost_json
    : requirements
      <generating-rule>@copy-printers
    ;

install install : printers : <location>(libdir) ;
explicit install ;


rule copy-printers ( project name : ps : script lib )
{
    if [ $(ps).get <link> ] != static
    {
        local lib-name = [ $(lib).name ] ;
        name = $(lib-name)-gdb.py ;
    }

    local lib-path  = [ $(lib).path ] ;
    ps = [ $(ps).add-raw <location>$(lib-path) ] ;

    local action = [ new action
          $(script)
        : common.copy
        : $(ps)
        ] ;
    local target = [ new file-target
        $(name) exact : [ type.type $(name) ] : $(project) : $(action) ] ;
    return [ property-set.empty ] [ virtual-target.register $(target) ] ;
}
